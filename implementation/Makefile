ifdef ANYPOINT_ORG
ORG_ARG := --org-id $(ANYPOINT_ORG)
endif

TARGET                := wasm32-wasip1
TARGET_DIR            := target/$(TARGET)/release
BUILD_POLICY_DIR      := target/$(TARGET)/release
CRATE_NAME             = $(shell cargo anypoint get-name)
DEFINITION_GAV         = $(shell cargo anypoint get-policy-definition-gav $(ORG_ARG))
POLICY_REF_NAME        = $(shell cargo anypoint get-policy-implementation-name)
DEFINITION_NAMESPACE  := default
MIN_FLEX_VERSION      := 1.9.3
OAUTH_TOKEN            = $(shell anypoint-cli-v4 pdk get-token)

.PHONY: setup
setup: install-cargo-anypoint ## Install toolchain and fetch deps
	cargo fetch

# NOTE: src/generated/config.rs is hand-maintained and intentionally NOT
# regenerated by `cargo anypoint config-gen`. The `adHocRecognizers` entries are
# forwarded verbatim to Presidio's /analyze (typed here as Vec<serde_json::Value>),
# which the generator represents as a fixed struct that silently drops unknown
# fields and is incompatible with the typed view in src/config.rs. Running it
# breaks the build, so it is a manual, opt-in target. When the GCL schema
# changes, update src/generated/config.rs and src/config.rs by hand.
.PHONY: config-gen
config-gen: ## (manual, advanced) Regenerate config.rs — WILL clobber hand edits
	@cargo anypoint config-gen --manifest ../definition/gcl.yaml --output ./src/generated/config.rs $(ORG_ARG)

.PHONY: build-asset-files
build-asset-files: ## Fetch the released definition from Exchange (by GAV)
	@anypoint-cli-v4 pdk fetch-policy --gav=$(DEFINITION_GAV)

.PHONY: build
build: ## Build the WASM binary + implementation policy artifacts
	@cargo build --target $(TARGET) --release
	@cargo anypoint build-policy --target=$(BUILD_POLICY_DIR) --wasm=$(TARGET_DIR)/$(CRATE_NAME).wasm $(ORG_ARG) --min-runtime-version=$(MIN_FLEX_VERSION)
	@anypoint-cli-v4 pdk install-policy --target $(TARGET_DIR) --path $(BUILD_POLICY_DIR)/$(CRATE_NAME)/implementation/

.PHONY: test-unit
test-unit: ## Run host-side unit + integration tests
	@cargo test

.PHONY: test
test: build test-unit ## Build then run the full test suite

.PHONY: run
run: build ## Build and boot the local playground (Flex + Presidio)
	@anypoint-cli-v4 pdk patch-gcl -f playground/config/api.yaml -p "spec.policies[0].policyRef.name" -v "$(POLICY_REF_NAME)"
	@anypoint-cli-v4 pdk patch-gcl -f playground/config/api.yaml -p "spec.policies[0].policyRef.namespace" -v "$(DEFINITION_NAMESPACE)"
	rm -f playground/config/custom-policies/*.yaml
	mkdir -p playground/config/custom-policies
	@anypoint-cli-v4 pdk install-policy --target playground/config/custom-policies --path $(BUILD_POLICY_DIR)/$(CRATE_NAME)/implementation/
	-docker compose -f ./playground/docker-compose.yaml down
	docker compose -f ./playground/docker-compose.yaml up

.PHONY: publish
publish: build-asset-files build ## Publish a development version of the implementation
	@anypoint-cli-v4 pdk policy-wasm publish --wasm=$(TARGET_DIR)/$(CRATE_NAME).wasm --target=$(BUILD_POLICY_DIR)/$(CRATE_NAME) --dev

.PHONY: release
release: build-asset-files build ## Release the implementation to Exchange
	@anypoint-cli-v4 pdk policy-wasm publish --wasm=$(TARGET_DIR)/$(CRATE_NAME).wasm --target=$(BUILD_POLICY_DIR)/$(CRATE_NAME)

.PHONY: login
login: ## Log in to the cargo registry with an Anypoint token
	@cargo login $(OAUTH_TOKEN)

.PHONY: install-cargo-anypoint
install-cargo-anypoint:
	cargo install cargo-anypoint@1.9.0

.PHONY: show-policy-ref-name
show-policy-ref-name:
	@echo $(POLICY_REF_NAME)

ifneq ($(OS), Windows_NT)
all: help

.PHONY: help
help:
	@echo 'Usage: make <target>'
	@echo ''
	@grep -Eh '^\w[^:]+:.*?## .*$$' $(MAKEFILE_LIST) \
		| awk 'BEGIN {FS = ":.*?## "}; {printf "\033[36m%-20s\033[0m %s\n", $$1, $$2}' \
		| sort
endif
